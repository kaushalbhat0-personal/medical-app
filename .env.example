# Supabase: Dashboard → Project Settings → Database → Connection string → URI
# Use "Session mode" (recommended for SQLAlchemy server apps) or the pooler URI if you prefer.
# If the URI has no SSL query param, append ?sslmode=require (or &sslmode=require if it already has ?).

DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
